{
  "name": "acl-proxy",
  "version": "0.1.0",
  "private": true,
  "description": "HTTP/HTTPS proxy with path-aware URL allow/deny policy",
  "main": "dist/index.js",
  "bin": {
    "extract-capture-body": "dist/cli/extract-capture-body.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "npm run build && jest",
    "test:unit": "npm run build && jest test/unit",
    "test:integration": "npm run build && jest test/integration",
    "test:watch": "npm run build && jest --watch",
    "test:coverage": "npm run build && jest --coverage"
  },
  "dependencies": {
    "commander": "^11.0.0",
    "node-forge": "^1.3.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/node-forge": "^1.3.14",
    "axios": "^1.13.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
